# Kontak yang dibuka setelah pengunjung submit form (server-only, isi di Vercel)
CONTACT_EMAIL=<GANTI_DENGAN_EMAIL_KAMU>
CONTACT_WA=<GANTI_DENGAN_NOMOR_WA_KAMU_FORMAT_62>

# Notifikasi email via Resend (opsional - tanpa ini notif dilewati, kontak tetap terbuka)
RESEND_API_KEY=<GANTI_DENGAN_API_KEY_RESEND>
NOTIF_TO_EMAIL=<GANTI_DENGAN_EMAIL_PENERIMA_NOTIF>

# Domain situs (opsional, untuk share preview/OG image resolve URL absolut yang benar).
# Kalau kosong di Vercel, otomatis pakai VERCEL_URL.
NEXT_PUBLIC_SITE_URL=<GANTI_DENGAN_DOMAIN_SITUS_KAMU>

# Database (opsional). Tambah Vercel Postgres/Neon dari dashboard Vercel (Storage > Create Database),
# POSTGRES_URL otomatis ke-inject - tidak perlu diisi manual. Tanpa ini, submission tidak disimpan
# (cuma notifikasi email kalau Resend diisi).
# POSTGRES_URL diisi otomatis oleh Vercel, jangan isi manual di sini.

# Rate limit persisten via Upstash Redis (opsional, gratis di upstash.com).
# Tanpa ini, rate limit tetap jalan tapi cuma in-memory per instance (kurang konsisten di serverless).
UPSTASH_REDIS_REST_URL=<GANTI_DENGAN_URL_UPSTASH>
UPSTASH_REDIS_REST_TOKEN=<GANTI_DENGAN_TOKEN_UPSTASH>

# CAPTCHA via Cloudflare Turnstile (opsional, gratis di dash.cloudflare.com/?to=/:account/turnstile).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY dipakai di browser (aman, bukan rahasia).
# Tanpa ini, form tetap jalan tanpa CAPTCHA.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<GANTI_DENGAN_SITE_KEY_TURNSTILE>
TURNSTILE_SECRET_KEY=<GANTI_DENGAN_SECRET_KEY_TURNSTILE>
